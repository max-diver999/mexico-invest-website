        <tr><td><strong>TOTAL sitemap</strong></td><td class="count">201</td><td><strong>~528 000 words</strong> · 14 git commits · build green</td></tr>
      </tbody>
    </table>
  </div>

  <div class="section-title">Infrastructure &amp; indexing</div>
  <div class="info-grid">
    <div class="info-card">
      <h3>Stack</h3>
      <div class="info-row"><span class="key">Domain</span><span class="val"><a href="https://mexico-invest.com/">mexico-invest.com</a></span></div>
