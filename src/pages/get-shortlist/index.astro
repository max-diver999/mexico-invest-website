---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
---
<BaseLayout
  title="Get Your Mexico Property Shortlist"
  description="Tell us your budget and target market (Riviera Maya, Los Cabos, RAK). Free independent shortlist within one business day."
>
  <section class="site-container py-12 md:py-16 max-w-2xl">
    <header class="mb-8">
      <h1 class="mb-3">Get your shortlist</h1>
      <p class="text-lg text-[var(--color-muted)]">
        Share budget, market, and goal. We match you with vetted off-plan and ready options — no spam, no developer pressure.
      </p>
    </header>
    <LeadForm
      title="Request your shortlist"
      subtitle="Licensed partner review · Riviera Maya · Los Cabos · PV"
      context="Get shortlist page"
    />
    <p class="text-xs text-[var(--color-muted)] mt-6">
      By submitting you agree to our <a href="/privacy-policy/">Privacy Policy</a>.
      Not financial or legal advice.
    </p>
  </section>
</BaseLayout>
