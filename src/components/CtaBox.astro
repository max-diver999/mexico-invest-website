---
interface Props {
  title: string;
  description: string;
  buttonText?: string;
  href?: string;
}

const {
  title,
  description,
  buttonText = 'Get your shortlist →',
  href = '/get-shortlist/',
} = Astro.props;
---
<aside class="surface-card p-6 md:p-8 my-8 border-l-4 border-[var(--color-primary)]">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div class="flex-1">
      <h3 class="text-xl font-semibold mb-2 text-[var(--color-ink)]">{title}</h3>
      <p class="text-[var(--color-muted)] text-sm">{description}</p>
    </div>
    <div class="flex-shrink-0">
      <a href={href} class="btn-primary inline-block px-6 py-3 text-center whitespace-nowrap">
        {buttonText}
      </a>
    </div>
  </div>
</aside>
